{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "es6"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "build",
    "scripts",
    "acceptance-tests",
    "webpack",
    "jest",
    "src/setupTests.ts",
    "apps/data-availability/build",
    "apps/data-availability/node_modules",
    "apps/data-product-detail/build",
    "apps/data-product-detail/node_modules",
    "apps/explore-data-products/build",
    "apps/explore-data-products/node_modules",
    "apps/prototype-data/build",
    "apps/prototype-data/node_modules",
    "apps/sample-explorer/build",
    "apps/sample-explorer/node_modules",
    "apps/taxonomic-lists/build",
    "apps/taxonomic-lists/node_modules",
  ]
}
